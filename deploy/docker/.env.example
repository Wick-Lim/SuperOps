# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# PostgreSQL
DB_HOST=postgres
DB_PORT=5432
DB_USER=superops
DB_PASSWORD=changeme_db_password
DB_NAME=superops
DB_SSLMODE=disable
DB_MAX_CONNS=25
DB_MIN_CONNS=5
POSTGRES_PASSWORD=changeme_db_password

# Redis
REDIS_ADDR=redis:6379
REDIS_PASSWORD=changeme_redis_password

# NATS
NATS_URL=nats://nats:4222

# JWT
JWT_SECRET=changeme_jwt_secret_at_least_32_chars_long
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=changeme_minio_password
MINIO_BUCKET=superops
MINIO_USE_SSL=false

# Meilisearch
MEILI_HOST=http://meilisearch:7700
MEILI_MASTER_KEY=changeme_meili_master_key

# Logging
LOG_LEVEL=info
